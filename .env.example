# NetAlign - Environment Variables Configuration Template
# Copy this file to a new file named ".env" in the same directory and modify the values.

# The port that the Hono backend server will listen on
# Fallback default: 5000 (required for default Vite dev proxy)
PORT=5000

# Environment mode (development, production, test)
NODE_ENV=development

# SQLite database file path (optional)
# Default: server/data/netalign.db
# NETALIGN_DB_PATH=server/data/netalign.db

# Skip auto-import of JSON seed files on first startup (optional, for tests)
# NETALIGN_SKIP_JSON_MIGRATE=1

# --- Frontend Deployment (Cross-Origin Reference) ---
# If deploying the frontend separately (e.g., Netlify, Vercel) and backend on a VPS:
# Update the production API fallback URL in "src/api.ts" with your live domain:
# e.g. return 'https://api.netalign.wardix.com';