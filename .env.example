# NetAlign - Environment Variables Configuration Template
# Copy this file to a new file named ".env" in the same directory and modify the values.

# The port that the Hono backend server will listen on
# Fallback default: 5000 (required for default Vite dev proxy)
PORT=5000

# Environment mode (development, production, test)
NODE_ENV=development

# SQLite database file path (optional)
# Default: server/data/netalign.db
# NETALIGN_DB_PATH=server/data/netalign.db

# Skip auto-import of JSON seed files on first startup (optional, for tests)
# NETALIGN_SKIP_JSON_MIGRATE=1

# Comma-separated browser origins allowed to call the API (CORS).
# Development default (when unset): http://localhost:3000 and common Vite ports.
# Production (when unset): deny cross-origin browser access — set your frontend URL(s).
# Use * only if you intentionally allow any origin.
# CORS_ORIGINS=https://app.example.com,https://www.example.com

# --- Frontend (Vite) ---
# Backend origin embedded at build time for split deployments.
# Leave empty or omit for same-origin / Vite dev proxy (`/api` → localhost:5000).
# VITE_API_BASE=https://api.example.com
